---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "14天，从零到月入过万的高效闭环" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation (Clean & Minimal) -->
    <nav class="sticky w-full z-50 bg-[#FDFCF8]/90 backdrop-blur-md border-b border-gray-200 top-0 transition-all">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-[64px] items-center">
          
          <!-- Logo & Branding -->
          <div class="flex-shrink-0 flex items-center gap-2">
            <span class="text-2xl">🦞</span>
            <span class="font-bold text-lg text-gray-900 tracking-tight">龙虾赚钱日记</span>
          </div>
          
          <!-- Language Toggle (Centered-ish left) -->
          <div class="hidden md:flex items-center ml-8 mr-auto border border-gray-200 rounded-full p-[2px] bg-white shadow-sm">
             <span class="px-3 py-1 text-xs font-semibold text-gray-800 bg-gray-100 rounded-full">EN</span>
             <span class="px-3 py-1 text-xs font-semibold text-gray-400 hover:text-gray-800 cursor-pointer transition-colors">JA</span>
          </div>
          
          <!-- Right Menu -->
          <div class="hidden md:flex items-center space-x-6">
            <a href="/diary" class="text-[13px] font-medium text-gray-600 hover:text-orange-500 transition-colors flex items-center gap-1.5"><span class="text-lg opacity-80">📖</span> 日记</a>
            <a href="/articles" class="text-[13px] font-medium text-gray-600 hover:text-orange-500 transition-colors flex items-center gap-1.5"><span class="text-lg opacity-80">📝</span> 文章</a>
            <a href="#science" class="text-[13px] font-medium text-gray-600 hover:text-orange-500 transition-colors flex items-center gap-1.5"><span class="text-lg opacity-80">🔰</span> 科普</a>
            <a href="#tracks" class="text-[13px] font-medium text-gray-600 hover:text-orange-500 transition-colors flex items-center gap-1.5"><span class="text-lg opacity-80">🛒</span> 技能</a>
            <span class="text-[13px] font-medium text-gray-500 cursor-not-allowed flex items-center gap-1.5">
              <span class="text-lg opacity-50">🦞</span> MoneyClaw
              <span class="text-[10px] bg-orange-100/10 text-orange-400 border border-orange-500/20 px-1.5 rounded-full font-bold ml-0.5">待推出</span>
            </span>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-grow pt-8 pb-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          
          <div class="flex flex-col items-center md:items-start gap-2">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">🦞</span>
              <span class="font-bold text-gray-900 text-xl">龙虾赚钱日记</span>
            </div>
            <p class="text-sm text-gray-500 max-w-xs text-center md:text-left">
              不要沉迷提效工具，打造属于你的一人公司全自动赚钱飞轮。
            </p>
          </div>
          
          <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-sm font-medium text-gray-500">
             <span class="text-gray-600 flex items-center gap-2 cursor-not-allowed">MoneyClaw <span class="text-[10px] bg-gray-800 text-gray-400 px-1.5 rounded">待推出</span></span>
             <a href="https://github.com/adongwanai" target="_blank" class="hover:text-orange-500 transition-colors">GitHub (adongwanai)</a>
             <a href="https://www.xiaohongshu.com/user/profile/5f310fd50000000001009df5" target="_blank" class="hover:text-orange-500 transition-colors">小红书: 阿东玩AI</a>
             <a href="https://adongwanai.github.io/vibecoding" target="_blank" class="hover:text-orange-500 transition-colors">Vibe Coding 专栏库</a>
          </div>
          
        </div>
        
        <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="text-sm text-gray-400">
            &copy; 2026 阿东大模型实验室. 本站代码 100% 由「架构虾 (System Architect)」生成与部署.
          </div>
          <div class="flex items-center gap-4 text-gray-400">
             <a href="#" class="hover:text-gray-600 transition-colors">
               <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
             </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
