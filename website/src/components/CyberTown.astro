    "正在Vibe新产品，制定Marketing策略 📈",
    "正在剪辑爆款短视频 ✂️",
    "达成一笔新交易 💰",
    "深度学习爆款文案中 📚",
    "自动回复了 15 个客户",
    "一键分发到推特和红书 🚀",
    "与带货虾交换情报 🤝",
    "正在抓取全网最新干货 📡"
  ];

  // 工作消息
  const workMessages = [
    '刚发了3篇笔记 💰',
    '收到会员费 +¥99',
    '带货转化率 12%',
    '视频剪辑完成 ✂️',
    '客户已回复 ✓',
    '自动收款中...',
    '内容已发布 📝',
    '新订单 +¥199',
  ];

  // 滚动触发
  ScrollTrigger.create({
    trigger: "#cyber-town-section",
    start: "top 60%",
    onEnter: () => {
      initTown();
    },
    once: true
  });

  function initTown() {
    const lobsterArea = document.getElementById('lobster-area');
    const coinRain = document.getElementById('coin-rain');
    const messageBubbles = document.getElementById('message-bubbles');

    if (!lobsterArea || !coinRain || !messageBubbles) return;

    // 生成龙虾
    for (let i = 0; i < 12; i++) {
      setTimeout(() => {
        createLobster(lobsterArea, i);
      }, i * 200);
    }

    // 持续掉金币
    setInterval(() => {
      createCoin(coinRain);
    }, 300);

    // 随机消息气泡
    setInterval(() => {
      if (Math.random() > 0.5) {
        createBubble(messageBubbles);
      }
    }, 2000);
  }

  // 龙虾状态池 (引入真实的不稳定因素)
  const statusPool = [
    { type: 'working', label: '' },
    { type: 'working', label: '' },
    { type: 'working', label: '' },
    { type: 'working', label: '' },
    { type: 'working', label: '' },
    { type: 'sick', label: '🤒 赛博感冒(Bug修复中)' },
    { type: 'sleeping', label: '💤 算力耗尽休眠中' },
    { type: 'warning', label: '⚠️ API触发频控罢工' }
  ];

  function createLobster(container: HTMLElement, index: number) {
    const type = lobsterTypes[index % lobsterTypes.length];
    const status = statusPool[Math.floor(Math.random() * statusPool.length)];
    const lobster = document.createElement('div');
    lobster.className = 'lobster';
    lobster.dataset.status = status.type;

    // 随机初始位置
    const startX = 10 + Math.random() * 75;
    const startY = 55 + Math.random() * 30;

    // Ensure lobster starts at random positions clearly across the view
    lobster.style.left = `${startX}%`;
    lobster.style.bottom = `${startY}%`;

    const isSick = status.type !== 'working';
    const filterStyle = isSick ? 'filter: grayscale(100%) sepia(50%) hue-rotate(-50deg); opacity: 0.6;' : '';

    lobster.innerHTML = `
      <div class="lobster-action" id="action-${index}">${status.label}</div>
      <div class="lobster-name" style="${isSick ? 'color: #ef4444; border-color: #ef4444;' : ''}">${type.name}</div>
      <div class="lobster-emoji" style="${filterStyle}">🦞</div>
    `;

    container.appendChild(lobster);

    // Give it a brief delay before starting interaction
    setTimeout(() => { animateLobster(lobster, isSick); }, Math.random() * 2000);
  }

  function animateLobster(lobster: HTMLElement, isSick: boolean) {
    if (isSick) {
      // 罢工/生病的龙虾不移动，只偶尔闪烁状态气泡
      const actionEl = lobster.querySelector('.lobster-action');
      setInterval(() => {
        if (actionEl && Math.random() > 0.3) {
           actionEl.classList.add('show');
           setTimeout(() => { actionEl.classList.remove('show'); }, 3000);
        }
      }, 5000 + Math.random() * 5000);
      return; 
    }

    const move = () => {
      // 跑到建筑附近，扩大活动范围，避免挤在左侧
      const newX = 5 + Math.random() * 85; 
      const newY = 30 + Math.random() * 45;
      const duration = 2 + Math.random() * 4;

      lobster.classList.add('working');

      gsap.to(lobster, {
        left: `${newX}%`,
        bottom: `${newY}%`,
        duration: duration,
        ease: "power1.inOut",
        onComplete: () => {
          lobster.classList.remove('working');
          
          // 悬停时随机弹出动态交互气泡
          const actionEl = lobster.querySelector('.lobster-action');
          if (actionEl && Math.random() > 0.4) {
             actionEl.textContent = livelyActions[Math.floor(Math.random() * livelyActions.length)];
             actionEl.classList.add('show');
             // 2.5秒后隐藏气泡
             setTimeout(() => {
                actionEl.classList.remove('show');
             }, 2500);
          }

          // 休息一会儿继续移动
          setTimeout(move, 3000 + Math.random() * 2000);
        }
      });
    };

    move();
  }

  function createCoin(container: HTMLElement) {
    const coin = document.createElement('div');
    coin.className = 'coin';
    coin.textContent = '💰';

    const startX = Math.random() * 90 + 5;
    const duration = 2 + Math.random() * 2;

    coin.style.left = `${startX}%`;
    coin.style.top = '0';
    coin.style.animationDuration = `${duration}s`;

    container.appendChild(coin);

    setTimeout(() => {
      coin.remove();
    }, duration * 1000);
  }

  function createBubble(container: HTMLElement) {
    const bubble = document.createElement('div');
    bubble.className = 'message-bubble';

    const message = workMessages[Math.floor(Math.random() * workMessages.length)];
    const startX = 15 + Math.random() * 70;

    bubble.textContent = message;
    bubble.style.left = `${startX}%`;
    bubble.style.bottom = '35%';

    container.appendChild(bubble);

    setTimeout(() => {
      bubble.remove();
    }, 3000);
  }
}
</script>
