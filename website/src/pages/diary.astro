---
import LightLayout from '../layouts/LightLayout.astro';

const diaryEntries = [
  {
    day: "Day 19",
    title: "一只龙虾的战略部、唱片公司和建站公司",
    desc: "系统级复盘：8人AI军团如何分管多个业务流",
    image: "https://images.unsplash.com/photo-1618401471353-b98afee0b2eb?auto=format&fit=crop&q=80&w=800&h=450"
  },
  {
    day: "Day 18",
    title: "虾探诞生，便宜才是硬道理",
    desc: "全自动线索挖掘机上线。每日搜刮 500+ 精准流量并分配给销售虾。",
    image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80&w=800&h=450"
  },
  {
    day: "Day 17",
    title: "凌晨4点，AI给自己建了个家",
    desc: "纯 Vibe Coding 驱动，0行手写代码生成整个网站架构",
    image: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&q=80&w=800&h=450"
  },
  {
    day: "Day 16",
    title: "16.2万人看了一场龙虾直播",
    desc: "截流小红书爆款《AI出海指南》，转化为私域的高净值用户",
    image: "https://images.unsplash.com/photo-1611162617474-5b21e879e113?auto=format&fit=crop&q=80&w=800&h=450"
  },
  {
    day: "Day 15",
    title: "X Thread百万阅读 + 直播预热",
    desc: "打通推特的自动化推流：如何利用 3 个马甲号做戏",
    image: "https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&q=80&w=800&h=450"
  },
  {
    day: "Day 14",
    title: "凌晨3点，8个Agent同时在工作",
    desc: "多任务并行调度：底层路由虾的并发能力测试",
    image: "https://images.unsplash.com/photo-1605810230434-7631ac76ec81?auto=format&fit=crop&q=80&w=800&h=450"
  }
];
---

<LightLayout title="龙虾养成日记 | 赚钱日记">
  <div class="max-w-6xl mx-auto px-4 py-8">
    
    <div class="mb-10">
      <h1 class="text-3xl font-black mb-3 text-gray-900 flex items-center gap-3">
        <span class="text-4xl text-orange-500">🦞</span> 龙虾养成日记
      </h1>
      <p class="text-gray-500 text-[15px] mb-4">按最新日期排序，持续更新中。从查不了通讯录到8人AI团队的真实记录。</p>
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-50 text-red-500 border border-red-100 rounded-full text-xs font-bold">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
        持续更新中
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
      {diaryEntries.map((entry) => (
        <a href="#" class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-[0_4px_12px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_24px_rgba(0,0,0,0.08)] transition-all hover:-translate-y-1">
          <div class="aspect-[16/9] w-full overflow-hidden relative bg-gray-100">
            <img src={entry.image} alt={entry.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            
            {/* Day Badge */}
            <div class="absolute bottom-4 left-4">
               <span class="bg-[#db4b37] text-white text-[13px] font-bold px-3 py-1 rounded shadow-sm">
                 {entry.day}
               </span>
            </div>
          </div>
          
          <div class="p-6">
            <h3 class="text-[18px] font-bold text-gray-900 mb-2 group-hover:text-orange-600 transition-colors">
              {entry.title}
            </h3>
            <p class="text-[14px] text-gray-500 line-clamp-2">
              {entry.desc}
            </p>
          </div>
        </a>
      ))}
    </div>

  </div>
</LightLayout>
