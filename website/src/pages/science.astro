<script>
  // Dynamic ROI Calculator
  document.addEventListener('DOMContentLoaded', () => {
    const apiCost = document.getElementById('apiCost');
    const orderProfit = document.getElementById('orderProfit');
    const apiCostVal = document.getElementById('apiCostVal');
    const orderProfitVal = document.getElementById('orderProfitVal');
    const totalROI = document.getElementById('totalROI');

    function calculateROI() {
      const api = parseInt(apiCost.value);
      const profit = parseInt(orderProfit.value);
      
      apiCostVal.innerText = `¥ ${api}`;
      orderProfitVal.innerText = `¥ ${profit}`;
      
      // Magic mockup formula: Total Revenue = (API spent * 3 daily interaction efficiency) * Profit - API Cost
      const revenue = (api * 3) * profit - api;
      totalROI.innerText = `¥ ${revenue.toLocaleString()}`;
    }

    apiCost.addEventListener('input', calculateROI);
    orderProfit.addEventListener('input', calculateROI);
    calculateROI();
    
    // Scroll Spy & Progress Bar Logic
    const sections = document.querySelectorAll('.chapter-section');
    const tocLinks = document.querySelectorAll('.toc-link');
    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');

    function onScroll() {
      let current = '';
      const offset = 200; // Trigger line
      
      sections.forEach(sec => {
        const top = sec.offsetTop;
        const height = sec.offsetHeight;
        if (window.scrollY >= (top - offset)) {
          current = sec.getAttribute('id');
        }
      });
      
      // Calculate total progress
      const scrollPosition = window.scrollY;
      const totalHeight = document.body.scrollHeight - window.innerHeight;
      const progressPercent = Math.min(100, Math.max(0, (scrollPosition / totalHeight) * 100));
      
      progressBar.style.width = `${progressPercent}%`;
      progressText.innerText = `${Math.round(progressPercent)}%`;

      // Update Navigation styling
      tocLinks.forEach(link => {
        link.classList.remove('text-[#ca3d2f]', 'font-black');
        link.classList.add('text-gray-400', 'font-bold');
        if (link.dataset.target === current) {
          link.classList.remove('text-gray-400', 'font-bold');
          link.classList.add('text-[#ca3d2f]', 'font-black');
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    // Trigger once on load
    onScroll();
  });
</script>
