---
import LightLayout from '../layouts/LightLayout.astro';

const topPacks = [
  {
    icon: "💼", title: "超级助理", desc: "你的全能私人助理——邮件、日程、搜索、文档，动动嘴就搞定", count: 6, suitable: "白领、管理者、创业者"
  },
  {
    icon: "✍️", title: "内容创作者", desc: "公众号、小红书、视频、音乐——全平台内容一条龙", count: 8, suitable: "自媒体人、品牌运营、个人IP", highlight: true
  },
  {
    icon: "📈", title: "股票分析师", desc: "实时行情、技术分析、买卖信号——7×24帮你盯盘", count: 4, suitable: "股民、投资者、量化爱好者"
  },
  {
    icon: "🌍", title: "出海运营官", desc: "多语言内容、海外社媒、跨境运营——搞定语言和时差", count: 6, suitable: "出海企业、跨境电商、海外市场"
  },
  {
    icon: "🛒", title: "电商运营", desc: "商品文案、竞品分析、数据监控——用AI代替重复劳动", count: 6, suitable: "电商卖家、品牌方、运营团队", highlight: true
  },
  {
    icon: "🦞", title: "三万同款团队", desc: "8个Agent各司其职——这不是一只龙虾，这是一支团队", count: 38, suitable: "傅盛亲自验证的完整配置", specialBorder: true
  }
];

const allSkills = [
  { icon: "🏗️", title: "多Agent团队配置", desc: "一只龙虾变一支团队——配置多个AI角色协作，总指挥+笔杆子+参谋+运营官。", tags: ["官方", "必装", "热门"] },
  { icon: "🌐", title: "网页搜索", desc: "Brave搜索+DuckDuckGo多引擎搜索，实时获取网络信息。", tags: ["官方", "必装"] },
  { icon: "🔬", title: "深度研究", desc: "多引擎搜索+网页提取+结构化分析报告。", tags: ["官方"] },
  { icon: "⛅️", title: "天气查询", desc: "全球天气实时查询，wttr.in + Open-Meteo 双源。", tags: ["官方", "必装"] },
  { icon: "📧", title: "邮件管理", desc: "飞书邮件监控+自动检查+智能回复。", tags: ["官方"] },
  { icon: "📄", title: "文档操作", desc: "跨平台文档读写、知识库管理、多维表格操作。", tags: ["官方"] },
  { icon: "💻", title: "代码助手", desc: "Claude Code/Codex写代码、改Bug、部署。PTY模式自动应答。", tags: ["官方"] },
  { icon: "🐙", title: "GitHub操作", desc: "仓库/Issues/PR/代码搜索/Actions，不开网页管GitHub。", tags: ["官方"] },
  { icon: "🧑‍🦲", title: "AI文本人性化", desc: "16种检测模式+6种风格转换，去除AI味。支持小红书/知乎/学术风格。", tags: ["官方", "必装"] },
  { icon: "💚", title: "微信公众号", desc: "写作风格+标题策略+排版规范，完整公众号创作流程。", tags: ["官方"] },
  { icon: "🐦", title: "Twitter / X", desc: "发推/Thread/转推/删除，全自动多账号矩阵运营。", tags: ["官方"] },
  { icon: "📕", title: "小红书运营", desc: "搜索笔记、发布内容、分析评论。基于高亮矩阵库。", tags: ["官方", "热门"] }
];
---

<LightLayout title="龙虾技能箱 | 赚钱日记">
  <div class="max-w-7xl mx-auto px-4 py-8">
    
    <!-- Top Packs Section -->
    <div class="mb-16">
      <h2 class="text-2xl font-black mb-6 text-gray-900 flex items-center gap-2">
        <span>📦</span> 技能包——一键安装，即刻上岗
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topPacks.map(pack => (
          <div class={`bg-white rounded-2xl p-6 border transition-shadow hover:shadow-lg ${pack.specialBorder ? 'border-[#ca3d2f] shadow-[0_0_15px_rgba(202,61,47,0.1)]' : 'border-gray-200 shadow-sm'}`}>
            <div class="text-3xl mb-4">{pack.icon}</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{pack.title}</h3>
            <p class="text-[14px] text-gray-500 mb-6 h-10">{pack.desc}</p>
            <div class="flex items-center gap-3">
              <span class={`px-3 py-1 rounded-full text-xs font-bold text-white ${pack.highlight ? 'bg-orange-500' : (pack.specialBorder ? 'bg-[#ca3d2f]' : 'bg-[#1e60d0]')}`}>
                {pack.count}个技能
              </span>
              <span class="text-[12px] text-gray-400 truncate flex items-center gap-1">
                {pack.specialBorder && <span class="text-yellow-500">⭐</span>} 适合: {pack.suitable}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- All Skills Section -->
    <div class="mb-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <h2 class="text-2xl font-black text-gray-900 flex items-center gap-2">
        <span>🔧</span> 全部技能
      </h2>
      <div class="flex flex-wrap gap-2 text-sm font-medium">
        <button class="bg-[#ca3d2f] text-white px-4 py-1.5 rounded-full shadow-sm">全部</button>
        <button class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full hover:border-gray-300">创作</button>
        <button class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full hover:border-gray-300">社媒</button>
        <button class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full hover:border-gray-300">研究</button>
        <button class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full hover:border-gray-300">办公</button>
        <button class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full hover:border-gray-300">开发</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {allSkills.map(skill => (
        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1">
          <div class="flex items-start gap-4 mb-3">
            <span class="text-3xl bg-gray-50 p-2 rounded-lg">{skill.icon}</span>
            <div>
              <h4 class="font-bold text-gray-900 text-[15px] mb-1 leading-tight">{skill.title}</h4>
              <div class="flex gap-1 flex-wrap">
                {skill.tags.map(tag => {
                  let badgeClass = "bg-green-50 text-green-600 border border-green-100";
                  if (tag === "必装") badgeClass = "bg-yellow-50 text-yellow-600 border border-yellow-100";
                  if (tag === "热门") badgeClass = "bg-red-50 text-red-500 border border-red-100";
                  
                  let prefix = "";
                  if (tag === "必装") prefix = "⭐ ";
                  if (tag === "热门") prefix = "🔥 ";
                  
                  return (
                    <span class={`text-[10px] px-1.5 py-0.5 rounded font-bold ${badgeClass}`}>
                      {prefix}{tag}
                    </span>
                  );
                })}
              </div>
            </div>
          </div>
          <p class="text-[13px] text-gray-500 leading-snug">
            {skill.desc}
          </p>
        </div>
      ))}
    </div>

  </div>
</LightLayout>
