---
import Layout from '../layouts/Layout.astro';

const skillCategories = [
  {
    title: "网页 & 前端",
    icon: "🌐",
    skills: ["frontend-design (高质量 UI)", "nextjs-expert (Next.js 应用)", "ui-audit (UI 自动审计)", "remotion-server (视频渲染)"]
  },
  {
    title: "编程 Agent",
    icon: "💻",
    skills: ["coding-agent (Claude/Codex)", "opencode-acp-control (OpenCode)", "claude-team (多 Agent 协作)", "skill-creator (创建技能)"]
  },
  {
    title: "营销 & 销售",
    icon: "📈",
    skills: ["seo-audit (SEO 分析)", "social-content (社交媒体)", "email-sequence (邮件营销)", "copywriting (文案优化)"]
  },
  {
    title: "AI & 大模型",
    icon: "🧠",
    skills: ["kimi-integration (Kimi 集成)", "chatgpt-apps (ChatGPT 应用)", "chromadb-memory (向量记忆)", "agentmemory (云端记忆)"]
  },
  {
    title: "DevOps & 云",
    icon: "☁️",
    skills: ["cloudflare (Workers/KV/D1)", "docker-essentials (容器管理)", "kubernetes (K8s 集群)", "coolify (自托管部署)"]
  },
  {
    title: "效率 & 知识",
    icon: "📚",
    skills: ["logseq (Logseq 集成)", "obsidian (Obsidian 库)", "notion (Notion API)", "newsletter-digest (文章摘要)"]
  }
];
---

<Layout title="技能库 | 龙虾赚钱日记">
  <div class="min-h-screen bg-black text-white pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-4">
      
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-black mb-6">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">
            CLAW_SKILLS_MARKET
          </span>
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          为你的龙虾军团装备“技能 U 盘”。一键安装，即插即用。打造你的全自动雇佣兵小队。（以下内容由 OpenClaw 101 社区强力驱动）
        </p>
        <div class="mt-6 font-mono text-sm bg-gray-900 border border-white/10 text-gray-400 inline-block px-4 py-2 rounded-lg">
          $ npx clawhub@latest install &lt;skill-name&gt;
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skillCategories.map(category => (
          <div class="bg-white/5 border border-white/10 p-6 rounded-2xl hover:border-green-500/50 transition-colors group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-green-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            
            <div class="relative z-10 flex items-center justify-between mb-6 border-b border-white/10 pb-4">
              <h2 class="text-xl font-bold flex items-center gap-2">
                <span class="text-2xl">{category.icon}</span>
                {category.title}
              </h2>
              <span class="px-2.5 py-1 text-[10px] font-mono bg-green-500/20 text-green-400 rounded-full border border-green-500/30">PACK</span>
            </div>

            <ul class="space-y-3 relative z-10">
              {category.skills.map(skill => {
                const [cmd, name] = skill.split(' (');
                return (
                  <li class="flex items-center gap-2 text-sm">
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-green-400 transition-colors"></span>
                    <span class="text-gray-300 font-medium whitespace-nowrap overflow-hidden text-ellipsis">{name.replace(')', '')}</span>
                    <span class="text-gray-600 font-mono text-xs ml-auto">[{cmd}]</span>
                  </li>
                );
              })}
            </ul>

            <div class="mt-8 relative z-10">
              <button class="w-full py-2.5 rounded-lg border border-white/20 text-gray-400 font-bold text-sm hover:bg-white hover:text-black transition-colors">
                INSTALL PACK
              </button>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center border-t border-white/10 pt-12">
        <h3 class="text-2xl font-bold mb-4">全网优质资源聚合</h3>
        <p class="text-gray-500 mb-8 max-w-2xl mx-auto">想浏览完整的 5000+ 社区技能集？想知道如何本地一键部署？</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
           <a href="https://github.com/mengjian-github/openclaw101" target="_blank" class="px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/20 rounded-full transition-all">
             贡献新技能到 OpenClaw 101 GitHub
           </a>
           <a href="https://openclaw101.dev/zh" target="_blank" class="px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white font-bold rounded-full transition-all shadow-[0_0_20px_rgba(249,115,22,0.4)]">
             前往 OpenClaw 101 中文手册
           </a>
        </div>
      </div>

    </div>
  </div>
</Layout>
