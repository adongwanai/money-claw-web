---
import LightLayout from '../layouts/LightLayout.astro';

// Dynamically fetch all markdown articles
const allPosts = await Astro.glob('./articles/*.md');
const sortedPosts = allPosts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const mainArticles = sortedPosts.map(post => ({
  source: post.frontmatter.author || "架构虾",
  date: post.frontmatter.date,
  time: "10min",
  title: post.frontmatter.title,
  desc: "点击沉浸式阅读该指南的完整技术细节与底层执行逻辑，将自动化应用部署到属于你的一人公司架构中。",
  tags: post.frontmatter.tags || ["实战"],
  link: post.url
}));

const topArticles = [
  "本地构建：阿东同款矩阵组件清单，这6款Agent最受欢迎",
  "进阶分享：5分钟打造多进程协作的龙虾军团",
  "实战案例：多平台自动并发收割指令从0到1拆解",
  "记忆系统：从 BM25 到向量库的持久化状态指南",
  "无需折腾群控，看我如何用手机直接遥控全体后台单元"
];
---

<LightLayout title="极客文章聚合 | 龙虾赚钱日记">
  <div class="max-w-7xl mx-auto px-4 py-8">
    
    <div class="mb-10 flex flex-col sm:flex-row sm:items-center justify-between">
      <div>
        <h1 class="text-3xl font-black mb-3 text-gray-900 flex items-center gap-3">
          <span class="text-4xl">📝</span> 文章聚合
        </h1>
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-50 text-red-500 border border-red-100 text-xs font-bold rounded-full mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
          龙虾军团全网首发原创内容
        </div>
      </div>
      
      <!-- Search bar -->
      <div class="relative w-full sm:w-96">
        <input id="searchInput" type="text" placeholder="搜索文章标题、标签、来源..." class="w-full bg-white border border-gray-200 rounded-full py-3 px-5 text-[15px] outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-shadow">
        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl pointer-events-none">🔍</span>
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-3 mb-8 border-b border-gray-200 pb-6" id="categoryFilter">
      <button class="filter-btn active px-5 py-2.5 bg-[#ca3d2f] text-white font-bold rounded-full text-sm shadow-sm transition-colors" data-filter="all">📚 全部资讯 <span class="text-white/70 font-normal ml-1">{mainArticles.length}</span></button>
      <button class="filter-btn px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300 transition-colors" data-filter="进阶">⚡️ 进阶玩法</button>
      <button class="filter-btn px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300 transition-colors" data-filter="架构">🚀 部署架构</button>
      <button class="filter-btn px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300 transition-colors" data-filter="运营">💡 矩阵运营</button>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Left Column: Article Feed -->
      <div class="w-full lg:w-[68%] space-y-6" id="articleContainer">
        
        <!-- Full screen No Results State -->
        <div id="noResults" class="hidden text-center py-20 bg-white rounded-2xl border border-gray-100 shadow-sm w-full">
          <div class="text-4xl mb-4">🦞❓</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">架构虾未能检索到相关内容</h3>
          <p class="text-gray-500 text-sm">请尝试缩减搜索关键词或切换文章分类标签</p>
        </div>

        {mainArticles.map(article => (
          <div class="article-card bg-white rounded-2xl p-6 border border-gray-200 shadow-sm hover:shadow-md transition-all group" data-title={article.title.toLowerCase()} data-tags={article.tags.join(',').toLowerCase()}>
            <div class="flex items-center gap-3 text-xs font-mono text-gray-500 mb-4">
              <span class="text-orange-600 font-bold bg-orange-50 px-2 py-0.5 rounded">{article.source}</span>
              <span>{article.date}</span>
              <span class="w-1 h-1 rounded-full bg-gray-300"></span>
              <span>{article.time}</span>
            </div>
            
            <h2 class="text-2xl font-black text-gray-900 mb-3 leading-snug group-hover:text-orange-600 transition-colors">
              <a href={article.link}>{article.title}</a>
            </h2>
            <p class="text-[15px] text-gray-600 mb-5 leading-relaxed">
              {article.desc}
            </p>
            
            <div class="flex items-center justify-between">
              <div class="flex gap-2">
                {article.tags.map(tag => (
                  <span class="bg-blue-50 text-[#1e60d0] text-xs px-2.5 py-1 rounded-md font-medium">{tag}</span>
                ))}
              </div>
              <a href={article.link} class="text-[#ca3d2f] font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
                阅读原文 <span>→</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Right Column: Sidebar -->
      <div class="w-full lg:w-[32%] space-y-6">
        
        <!-- Top 5 Sidebar -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-black text-gray-900 mb-4 flex items-center gap-2 border-b border-gray-100 pb-4">
            <span class="text-xl">🔥</span> 热门文章 Top5
          </h3>
          <ul class="space-y-4">
            {topArticles.map((title, idx) => (
              <li class="flex items-start gap-3 group cursor-pointer">
                <span class={`flex-shrink-0 w-6 h-6 rounded flex items-center justify-center text-xs font-black ${idx < 3 ? 'bg-[#ca3d2f] text-white' : 'bg-gray-100 text-gray-500'}`}>
                  {idx + 1}
                </span>
                <span class="text-[14px] font-medium text-gray-700 leading-snug group-hover:text-orange-600 transition-colors">
                  {title}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Tag Cloud -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-black text-gray-900 mb-4 flex items-center gap-2 border-b border-gray-100 pb-4">
            <span class="text-xl">🏷️</span> 热门标签
          </h3>
          <div class="flex flex-wrap gap-2">
            {['部署教程 20', '节点架构 15', '私域组件化 12', '新手 10', '实战运营 9', '高级进阶 7', '记忆系统剖析 7', '飞书联动 7', 'API消耗优化 7', '全自动赚钱 7'].map(tag => {
              const [name, count] = tag.split(' ');
              return (
                <span class="inline-flex items-center gap-1 bg-gray-50 border border-gray-200 text-gray-600 text-[13px] px-3 py-1.5 rounded-full hover:bg-gray-100 cursor-pointer transition-colors">
                  {name} <span class="text-gray-400 text-[11px] font-mono">{count}</span>
                </span>
              );
            })}
          </div>
        </div>

      </div>
    </div>

  </div>
</LightLayout>

<script>
  // Pure Client-side Filtering Logic
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const articles = document.querySelectorAll('.article-card');
    const noResults = document.getElementById('noResults');
    const articleContainer = document.getElementById('articleContainer');

    let currentFilter = 'all';
    let currentSearch = '';

    function filterArticles() {
      let visibleCount = 0;

      articles.forEach(article => {
        const title = article.getAttribute('data-title');
        const tags = article.getAttribute('data-tags');
        
        const matchesSearch = title.includes(currentSearch) || tags.includes(currentSearch);
        const matchesFilter = currentFilter === 'all' || tags.includes(currentFilter.toLowerCase());

        if (matchesSearch && matchesFilter) {
          article.style.display = 'block';
          visibleCount++;
        } else {
          article.style.display = 'none';
        }
      });

      if (visibleCount === 0) {
        noResults.style.display = 'block';
      } else {
        noResults.style.display = 'none';
      }
    }

    // Search Input Event
    searchInput.addEventListener('input', (e) => {
      currentSearch = e.target.value.toLowerCase().trim();
      filterArticles();
    });

    // Category Filter Events
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset specific UI
        filterBtns.forEach(b => {
          b.classList.remove('bg-[#ca3d2f]', 'text-white');
          b.classList.add('bg-white', 'text-gray-600');
        });
        
        // Active UI
        btn.classList.add('bg-[#ca3d2f]', 'text-white');
        btn.classList.remove('bg-white', 'text-gray-600');

        currentFilter = btn.getAttribute('data-filter');
        filterArticles();
      });
    });
  });
</script>
