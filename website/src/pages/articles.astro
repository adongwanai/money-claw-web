---
import LightLayout from '../layouts/LightLayout.astro';

const mainArticles = [
  {
    source: "科技媒体",
    date: "2026-03-04",
    time: "15min",
    title: "The Hacker News 原创：341 个恶意生态技能曝光，代理安全指南",
    desc: "Koi Security 审计发现部分自动化技能遭到供应链污染，龙虾用户必读安全加固实践。",
    tags: ["深度研究", "安全审计", "风控"],
    link: "/articles/letta-memory"
  },
  {
    source: "官方实战",
    date: "2026-03-03",
    time: "10min",
    title: "Windows本地满血部署全自动化矩阵，无需科学上网",
    desc: "免除 WSL 困扰，纯 Windows 环境下基于本地模型的全托管方案，自动接入钉钉/飞书。",
    tags: ["视频教程", "Windows", "部署"],
    link: "/articles/zapier-loop"
  },
  {
    source: "架构解析",
    date: "2026-03-01",
    time: "25min",
    title: "飞书官方：一文完全搞懂全自动化生态与对接指南",
    desc: "包含 Gateway-Node 架构深度解析、画布流转原理、自动化成本测算分析大全。",
    tags: ["飞书", "架构", "深度"],
    link: "/articles/mcp-skills"
  },
  {
    source: "YouTube",
    date: "2026-02-28",
    time: "12min",
    title: "AMD Developer Cloud 免费跑全自动业务流指南",
    desc: "使用 MI300X 192GB 企业级 GPU 免费运行大模型，通过 API 直接暴露给前端矩阵框架。",
    tags: ["视频教程", "算力白嫖", "云部署"],
    link: "/articles/letta-memory"
  }
];

const topArticles = [
  "本地构建：最佳生产力工具榜来了，这6款代理最受欢迎",
  "进阶分享：5分钟打造多进程协作军团",
  "实战案例：多平台自动并发响应从0到1拆解",
  "记忆系统：从 BM25 到向量库完整指南",
  "无需折腾群控系统，看我如何用手机直接遥控全体后台单元"
];
---

<LightLayout title="极客文章聚合 | 龙虾赚钱日记">
  <div class="max-w-7xl mx-auto px-4 py-8">
    
    <div class="mb-10 flex flex-col sm:flex-row sm:items-center justify-between">
      <div>
        <h1 class="text-3xl font-black mb-3 text-gray-900 flex items-center gap-3">
          <span class="text-4xl">📝</span> 文章聚合
        </h1>
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-50 text-red-500 border border-red-100 text-xs font-bold rounded-full mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
          龙虾军团全网首发原创内容
        </div>
      </div>
      
      <!-- Search bar -->
      <div class="relative w-full sm:w-96">
        <input type="text" placeholder="搜索文章标题、标签、来源..." class="w-full bg-white border border-gray-200 rounded-full py-3 px-5 text-[15px] outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-shadow">
        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">🔍</span>
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-3 mb-8 border-b border-gray-200 pb-6">
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-800 font-bold rounded-full text-sm shadow-sm hover:border-gray-300">📚 全部资讯 <span class="text-gray-400 font-normal ml-1">102</span></button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300">⚡️ 进阶玩法 <span class="text-gray-400">30</span></button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300">🚀 部署教程 <span class="text-gray-400">29</span></button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300">💡 使用技巧 <span class="text-gray-400">22</span></button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 font-medium rounded-full text-sm hover:border-gray-300">🔍 评测分析 <span class="text-gray-400">15</span></button>
      <button class="px-5 py-2.5 bg-[#ca3d2f] text-white font-bold rounded-full text-sm shadow-sm hover:bg-[#b03529]">🎬 视频教程 <span class="text-white/70 font-normal ml-1">6</span></button>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Left Column: Article Feed -->
      <div class="w-full lg:w-[68%] space-y-6">
        {mainArticles.map(article => (
          <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 text-xs font-mono text-gray-500 mb-4">
              <span class="text-orange-600 font-bold bg-orange-50 px-2 py-0.5 rounded">{article.source}</span>
              <span>{article.date}</span>
              <span class="w-1 h-1 rounded-full bg-gray-300"></span>
              <span>{article.time}</span>
            </div>
            
            <h2 class="text-2xl font-black text-gray-900 mb-3 leading-snug">
              {article.title}
            </h2>
            <p class="text-[15px] text-gray-600 mb-5 leading-relaxed">
              {article.desc}
            </p>
            
            <div class="flex items-center justify-between">
              <div class="flex gap-2">
                {article.tags.map(tag => (
                  <span class="bg-blue-50 text-[#1e60d0] text-xs px-2.5 py-1 rounded-md font-medium">{tag}</span>
                ))}
              </div>
              <a href={article.link} class="text-[#ca3d2f] font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
                阅读原文 <span>→</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Right Column: Sidebar -->
      <div class="w-full lg:w-[32%] space-y-6">
        
        <!-- Top 5 Sidebar -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-black text-gray-900 mb-4 flex items-center gap-2 border-b border-gray-100 pb-4">
            <span class="text-xl">🔥</span> 热门文章 Top5
          </h3>
          <ul class="space-y-4">
            {topArticles.map((title, idx) => (
              <li class="flex items-start gap-3 group cursor-pointer">
                <span class={`flex-shrink-0 w-6 h-6 rounded flex items-center justify-center text-xs font-black ${idx < 3 ? 'bg-[#ca3d2f] text-white' : 'bg-gray-100 text-gray-500'}`}>
                  {idx + 1}
                </span>
                <span class="text-[14px] font-medium text-gray-700 leading-snug group-hover:text-orange-600 transition-colors">
                  {title}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Tag Cloud -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-black text-gray-900 mb-4 flex items-center gap-2 border-b border-gray-100 pb-4">
            <span class="text-xl">🏷️</span> 热门标签
          </h3>
          <div class="flex flex-wrap gap-2">
            {['部署教程 20', '架构 15', '组件化 12', '新手 10', '视频教程 9', '高级进阶 7', '记忆系统剖析 7', '飞书联动 7', 'Token消耗优化 7', '开源动态 7'].map(tag => {
              const [name, count] = tag.split(' ');
              return (
                <span class="inline-flex items-center gap-1 bg-gray-50 border border-gray-200 text-gray-600 text-[13px] px-3 py-1.5 rounded-full hover:bg-gray-100 cursor-pointer transition-colors">
                  {name} <span class="text-gray-400 text-[11px] font-mono">{count}</span>
                </span>
              );
            })}
          </div>
        </div>

      </div>
    </div>

  </div>
</LightLayout>
